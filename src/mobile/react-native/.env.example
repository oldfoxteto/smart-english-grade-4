# Firebase Configuration
FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=ai-english-master.firebaseapp.com
FIREBASE_PROJECT_ID=ai-english-master
FIREBASE_STORAGE_BUCKET=ai-english-master.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abcdef123456789012345678
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Instructions:
# 1. Copy this file to .env
# 2. Replace the values with your actual Firebase config
# 3. Get your config from Firebase Console > Project Settings > General > Your apps
# 4. Add .env to .gitignore (already done)
