PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/lisan_dev
JWT_SECRET=change_this_to_a_long_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_to_another_long_secret
JWT_REFRESH_EXPIRES_IN=30d

# === OpenAI Configuration (Recommended) ===
# Get API key from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4-mini
OPENAI_API_BASE=https://api.openai.com/v1

# === Google AI Studio Configuration (Alternative to OpenAI) ===
# Get API key from: https://makersuite.google.com/app/apikey
GOOGLE_AI_STUDIO_API_KEY=
GOOGLE_AI_STUDIO_MODEL=gemini-2.5-flash

# === AI Configuration ===
LOG_LEVEL=info
REQUEST_LOG_ENABLED=true
AI_TIMEOUT_MS=15000
AI_RETRY_COUNT=2
RATE_LIMIT_AI_MAX=100

ERROR_MONITOR_WEBHOOK_URL=
ADMIN_EMAILS=admin@example.com

# Secret manager options:
# SECRET_MANAGER_PROVIDER=env|gcp
# APP_SECRETS_JSON={"JWT_SECRET":"...","JWT_REFRESH_SECRET":"..."}
# APP_SECRETS_FILE=/run/secrets/app-secrets.json
# GCP_SECRET_MAPPINGS={"JWT_SECRET":"projects/PROJECT_ID/secrets/JWT_SECRET/versions/latest","ERROR_MONITOR_WEBHOOK_URL":"projects/PROJECT_ID/secrets/ERROR_MONITOR_WEBHOOK_URL/versions/latest"}
# GCP_ACCESS_TOKEN=ya29...
