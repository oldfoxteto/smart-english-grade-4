{
  "name": "lisan-backend-mvp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "node --test tests/*.test.js",
    "db:migrate": "node scripts/run-sql-file.js sql/migrations/001_init_schema.sql",
    "db:seed": "node scripts/run-sql-file.js sql/migrations/002_seed_core.sql",
    "db:backup": "node scripts/backup-db.js",
    "db:restore": "node scripts/restore-db.js",
    "content:qa": "node scripts/content-qa.js",
    "test:e2e": "node --test tests/e2e.userJourney.test.js",
    "test:security": "node --test tests/security.api.test.js",
    "test:load": "node scripts/load-profile.js",
    "test:prelaunch": "npm test && npm run test:e2e && npm run test:security",
    "db:clean": "node scripts/clean-database.js",
    "db:reset": "npm run db:migrate && npm run db:seed",
    "test:openai": "node scripts/test-openai.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "supertest": "^7.1.1"
  }
}
