# Server Configuration
PORT=4000
NODE_ENV=development

# Client URL
CLIENT_URL=http://localhost:5174
CLIENT_URLS=http://localhost:5173,http://localhost:5174

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
ACCESS_COOKIE_NAME=lisan_access
REFRESH_COOKIE_NAME=lisan_refresh
COOKIE_SAME_SITE=strict
COOKIE_DOMAIN=

# OpenAI (optional, fallback mode when empty)
OPENAI_API_KEY=
GOOGLE_AI_STUDIO_API_KEY=
GOOGLE_AI_STUDIO_MODEL=gemini-2.5-flash

# Database (for future use)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smart_english
DB_USER=postgres
DB_PASSWORD=password
DB_FILE=./data.db

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
MAX_FRAMES_PER_MIN=20

# Firebase Admin (required for /api/v1/auth/firebase)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
# Or provide the whole JSON service account in one variable:
# FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}
